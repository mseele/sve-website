---
import Checkbox from './Checkbox.astro'

interface Props {
  id: string
  name: string
  class?: string
  creditor?: string
}

const { id, name, class: className, creditor = 'SV Eutingen 1947 e.V.' } = Astro.props
---

<Checkbox
  id={id}
  name={name}
  title={`Ich ermächtige den ${creditor}, den Rechnungsbetrag per SEPA-Lastschrift von meinem Konto einzuziehen.`}
  class={className}
/>