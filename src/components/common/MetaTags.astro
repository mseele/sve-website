---
import { SITE } from '@/config.mjs'
import { type MetaSEO } from '@/types'
import { SEO } from 'astro-seo'
import { getImage } from 'astro:assets'

export interface Props extends MetaSEO {
  dontUseTitleTemplate?: boolean
}

const getCanonical = (path = ''): string | URL => {
  const url = String(new URL(path, Astro.site))
  if (SITE.trailingSlash == false && path && url.endsWith('/')) {
    return url.slice(0, -1)
  } else if (SITE.trailingSlash == true && path && !url.endsWith('/')) {
    return url + '/'
  }
  return url
}

const {
  title = SITE.name,
  description = '',
  image: imageMetadata = SITE.defaultImage,

  noindex = false,
  nofollow = false,
  canonical = String(getCanonical(Astro.url.pathname)),

  ogTitle = title,
  ogType = 'website',
  ogLocale = `${SITE.language}_DE`,

  dontUseTitleTemplate = false,
} = Astro.props

const image = new URL(
        (
          await getImage({
            src: imageMetadata,
            width: 1200,
            height: 628,
          })
        ).src,
        Astro.site,
      )
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<SEO
  title={title}
  titleTemplate={dontUseTitleTemplate ? '%s' : `%s — ${SITE.name}`}
  description={description}
  canonical={canonical}
  noindex={noindex}
  nofollow={nofollow}
  openGraph={{
    basic: {
      title: ogTitle,
      type: ogType,
      image: image.toString(),
    },
    optional: {
      description: description,
      locale: ogLocale,
    },
  }}
/>

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="mask-icon" href="/favicon.svg" color="#FFFFFF" />
<link rel="sitemap" href="/sitemap-index.xml" />
